# Rust / Cargo build output
target/
**/target/

# Keep Cargo.lock committed for Xmip runtime/platform reproducibility.
# Do not add Cargo.lock here.

# Rust compiler intermediate artifacts
*.rlib
*.rmeta
*.d

# Local debug symbols and OS-specific build products generated under development
*.pdb

# Xmip local runtime proof artifacts
execution-context.pb
crash-once.marker
*.pb
*.checkpoint
*.runtime
*.audit.local
*.trace.local
*.tracking.local

# Local runtime data and embedded databases
data/
**/data/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
persistence-rocksdb/
**/persistence-rocksdb/
management.sqlite

# Local inbound/outbound test folders
/inbound/
/outbound/
/tmp/
/temp/
tmp/
temp/

# Environment and local settings
.env
.env.*
*.local

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/
**/logs/
